{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.ts": "explicit",
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "files.exclude": {
    "node_modules/": true,
    "dist/": true,
    ".idea/": true,
    ".tanstack/": true,
    ".next/": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "ios": true,
    "android": true,
    "vendor": true,
    ".idea/": true,
    ".tanstack/": true,
    ".next/": true
  },
  "typescript.tsdk": "node_modules/typescript/lib"
}
